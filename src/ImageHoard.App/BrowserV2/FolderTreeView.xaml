<UserControl
    x:Class="ImageHoard.App.BrowserV2.FolderTreeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:browse2="using:ImageHoard.Core.Browse2"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d"
    IsTabStop="True"
    UseSystemFocusVisuals="False"
    KeyDown="Root_KeyDown"
    automation:AutomationProperties.Name="Folder tree">
    <UserControl.Resources>
        <DataTemplate x:Key="FolderRowTemplate" x:DataType="browse2:FolderRow">
            <Grid
                Height="32"
                MinHeight="32"
                Background="Transparent"
                AllowDrop="True"
                CanDrag="True"
                DragStarting="FolderRow_DragStarting"
                DragOver="FolderRow_DragOver"
                Drop="FolderRow_Drop"
                Tapped="FolderRow_Tapped"
                DoubleTapped="FolderRow_DoubleTapped"
                RightTapped="FolderRow_RightTapped">
                <Grid Padding="0,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        x:Name="IndentHost"
                        Grid.Column="0"
                        Width="0"
                        HorizontalAlignment="Left" />
                    <Border
                        x:Name="ExpandToggleHost"
                        Grid.Column="1"
                        Width="28"
                        Height="28"
                        Margin="0,0,2,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Tapped="ExpandToggleHost_Tapped"
                        automation:AutomationProperties.Name="Expand or collapse folder">
                        <FontIcon
                            x:Name="ChevronIcon"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            FontSize="12"
                            Glyph="&#xE76C;" />
                    </Border>
                    <TextBlock
                        x:Name="NameText"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Text="{x:Bind Name, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        x:Name="SizeText"
                        Grid.Column="3"
                        MinWidth="56"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Text="{x:Bind SizeDisplay, Mode=OneWay}"
                        TextAlignment="Right"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        x:Name="ImageCountText"
                        Grid.Column="4"
                        MinWidth="48"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Text="{x:Bind ImageCountDisplay, Mode=OneWay}"
                        TextAlignment="Right"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        x:Name="DateText"
                        Grid.Column="5"
                        MinWidth="120"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Text="{x:Bind ModifiedDisplay, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </Grid>
                <Border
                    x:Name="SelectionIndicator"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Width="3"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    Canvas.ZIndex="1" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <Border
        x:Name="OuterBorder"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="4">
        <ScrollViewer
            x:Name="TreeScrollViewer"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            IsTabStop="False"
            BringIntoViewOnFocusChange="False">
            <controls:ItemsRepeater
                x:Name="TreeRepeater"
                ItemTemplate="{StaticResource FolderRowTemplate}"
                ElementPrepared="TreeRepeater_ElementPrepared"
                ElementClearing="TreeRepeater_ElementClearing">
                <controls:ItemsRepeater.Layout>
                    <controls:StackLayout Orientation="Vertical" Spacing="0" />
                </controls:ItemsRepeater.Layout>
            </controls:ItemsRepeater>
        </ScrollViewer>
    </Border>
</UserControl>
