<Window
    x:Class="ImageHoard.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ImageHoard.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ImageHoard">
    <Grid
        x:Name="RootGrid"
        KeyDown="RootGrid_KeyDown"
        IsTabStop="True">
        <Grid.Resources>
            <local:BoolToVisibilityConverter x:Key="BoolToVis" />
            <local:InvertedBoolToVisibilityConverter x:Key="InvBoolToVis" />
            <DataTemplate x:Key="BrowserFolderItemTemplate">
                <Grid MinHeight="28" Padding="0,2" DataContext="{Binding Content}">
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{Binding DisplayLabel}"
                        TextTrimming="CharacterEllipsis"
                        Visibility="{Binding IsRenaming, Converter={StaticResource InvBoolToVis}}" />
                    <TextBox
                        VerticalAlignment="Center"
                        Text="{Binding EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}}"
                        PreviewKeyDown="BrowserRenameTextBox_PreviewKeyDown"
                        LostFocus="BrowserRenameTextBox_LostFocus"
                        Loaded="BrowserRenameTextBox_Loaded" />
                </Grid>
            </DataTemplate>
            <DataTemplate x:Key="BrowserFileItemTemplate">
                <Grid MinHeight="28" Padding="0,2" DataContext="{Binding Content}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        ColumnSpacing="10"
                        Visibility="{Binding IsRenaming, Converter={StaticResource InvBoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <SymbolIcon
                                Grid.Column="0"
                                Width="14"
                                Height="14"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Symbol="{Binding SortFlagGlyphSymbol}"
                                Foreground="{Binding SortFlagGlyphForeground}"
                                Visibility="{Binding SortFlagGlyphVisibility}" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="{Binding DisplayName}"
                                TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            MinWidth="56"
                            TextAlignment="Right"
                            Text="{Binding SizeDisplay}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{Binding SizeDetailVisibility}" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            MinWidth="120"
                            Text="{Binding ModifiedDisplay}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{Binding DateDetailVisibility}" />
                    </Grid>
                    <TextBox
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        VerticalAlignment="Center"
                        Text="{Binding EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}}"
                        PreviewKeyDown="BrowserRenameTextBox_PreviewKeyDown"
                        LostFocus="BrowserRenameTextBox_LostFocus"
                        Loaded="BrowserRenameTextBox_Loaded" />
                </Grid>
            </DataTemplate>
            <DataTemplate x:Key="BrowserFileListHeaderTemplate">
                <Grid MinHeight="20" Padding="0,0,0,4" ColumnSpacing="10" DataContext="{Binding Content}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Opacity="0.9"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Name" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        MinWidth="56"
                        TextAlignment="Right"
                        Opacity="0.9"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Size"
                        Visibility="{Binding SizeHeaderVisibility}" />
                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        MinWidth="120"
                        Opacity="0.9"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Date modified"
                        Visibility="{Binding DateHeaderVisibility}" />
                </Grid>
            </DataTemplate>
        </Grid.Resources>
        <Grid x:Name="NormalLayout" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="160" />
            </Grid.RowDefinitions>
            <MenuBar Grid.Row="0">
                <MenuBarItem Title="File">
                    <MenuFlyoutItem Text="Open…" Click="OpenFolder_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Exit" Click="Exit_Click" />
                </MenuBarItem>
                <MenuBarItem Title="Browse">
                    <ToggleMenuFlyoutItem
                        x:Name="IncludeSubfoldersToggle"
                        Text="Include subfolders in list"
                        Click="IncludeSubfoldersToggle_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Go to path…" Click="BrowseGoToPath_Click" />
                    <MenuFlyoutItem Text="Add current folder to favorites" Click="BrowseAddFavorite_Click" />
                    <MenuFlyoutSubItem Text="Favorites">
                        <MenuFlyoutItem x:Name="FavoritePlaceholder" Text="(none)" IsEnabled="False" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Reveal in Explorer" Click="BrowseRevealInExplorer_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Compute folder metrics…" Click="BrowseComputeMetrics_Click" />
                </MenuBarItem>
                <MenuBarItem Title="View">
                    <ToggleMenuFlyoutItem
                        x:Name="ShowBrowserPaneToggle"
                        Text="Show browser pane"
                        Click="ShowBrowserPaneToggle_Click" />
                    <MenuFlyoutSubItem Text="Image overlay">
                        <ToggleMenuFlyoutItem
                            x:Name="ShowPathOnOverlayWindowedToggle"
                            Text="Show file path (windowed preview)"
                            Click="ShowPathOnOverlayWindowedToggle_Click" />
                        <ToggleMenuFlyoutItem
                            x:Name="ShowPathOnOverlayFullscreenToggle"
                            Text="Show file path (fullscreen)"
                            Click="ShowPathOnOverlayFullscreenToggle_Click" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutSubItem Text="Sort list by">
                        <RadioMenuFlyoutItem
                            x:Name="SortNameNaturalItem"
                            Text="Name (natural order)"
                            GroupName="ListSort"
                            Click="SortList_NameNatural_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="SortNameItem"
                            Text="Name (A–Z only)"
                            GroupName="ListSort"
                            Click="SortList_Name_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="SortDateItem"
                            Text="Date modified"
                            GroupName="ListSort"
                            Click="SortList_Date_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="SortSizeItem"
                            Text="Size"
                            GroupName="ListSort"
                            Click="SortList_Size_Click" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSubItem Text="File details">
                        <ToggleMenuFlyoutItem
                            x:Name="ShowBrowserFileColumnHeadingsToggle"
                            Text="Show column headings"
                            Click="ShowBrowserFileColumnHeadingsToggle_Click" />
                        <ToggleMenuFlyoutItem
                            x:Name="ShowBrowserFileSizeToggle"
                            Text="Show file size"
                            Click="ShowBrowserFileSizeToggle_Click" />
                        <ToggleMenuFlyoutItem
                            x:Name="ShowBrowserFileDateToggle"
                            Text="Show date modified"
                            Click="ShowBrowserFileDateToggle_Click" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutSubItem Text="Image fit">
                        <RadioMenuFlyoutItem
                            x:Name="FitModeFitItem"
                            Text="Fit"
                            GroupName="ImageFit"
                            Click="ViewFit_Fit_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="FitModeFillItem"
                            Text="Fill"
                            GroupName="ImageFit"
                            Click="ViewFit_Fill_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="FitModeOneToOneItem"
                            Text="1:1"
                            GroupName="ImageFit"
                            Click="ViewFit_OneToOne_Click" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        x:Name="EnterFullscreenMenuItem"
                        Text="Enter fullscreen"
                        Click="EnterFullscreen_Click" />
                </MenuBarItem>
                <MenuBarItem Title="Slideshow">
                    <MenuFlyoutItem Text="Start slideshow (tree)…" Click="SlideshowStart_Click" />
                    <MenuFlyoutItem Text="Toggle Tree / Folder scope" Click="SlideshowToggleScope_Click" />
                    <MenuFlyoutItem Text="Reshuffle session" Click="SlideshowReshuffle_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="About random fairness…" Click="SlideshowFairnessHelp_Click" />
                </MenuBarItem>
                <MenuBarItem Title="Sort">
                    <MenuFlyoutItem Text="Flag selection: Keep" Click="SortFlagKeep_Click" />
                    <MenuFlyoutItem Text="Flag selection: Delete" Click="SortFlagDelete_Click" />
                    <MenuFlyoutItem Text="Flag selection: Unset" Click="SortFlagUnset_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Batch delete (non-keepers)…" Click="SortBatchDelete_Click" />
                    <MenuFlyoutItem Text="Move current folder to archive…" Click="SortMoveArchive_Click" />
                </MenuBarItem>
                <MenuBarItem Title="Settings">
                    <MenuFlyoutItem Text="Preferences…" Click="OptionsPreferences_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Set archive root…" Click="SettingsArchiveRoot_Click" />
                    <MenuFlyoutItem Text="Clear caches (metrics)" Click="SettingsClearCaches_Click" />
                    <MenuFlyoutItem Text="Clear caches + operation log" Click="SettingsClearCachesAndLog_Click" />
                </MenuBarItem>
            </MenuBar>
            <Grid x:Name="ContentBelowMenu" Grid.Row="1" MinHeight="160">
                <Grid x:Name="BrowserPaneGrid" MinHeight="120">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="ColBrowser" MinWidth="120" Width="74*" />
                        <ColumnDefinition x:Name="ColGapBrowserPreview" Width="6" />
                        <ColumnDefinition x:Name="ColPreview" MinWidth="120" Width="26*" />
                    </Grid.ColumnDefinitions>
                    <Grid
                        x:Name="BrowserColumnHost"
                        Grid.Column="0"
                        MinWidth="120">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="80" />
                        </Grid.RowDefinitions>
                        <Grid
                            Grid.Row="0"
                            MinHeight="36"
                            Padding="0,4,0,4"
                            ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <AppBarButton
                                x:Name="BrowserNavigateUpButton"
                                Grid.Column="0"
                                Width="40"
                                Height="36"
                                IsCompact="True"
                                VerticalAlignment="Center"
                                LabelPosition="Collapsed"
                                Click="BrowserNavigateUp_Click"
                                ToolTipService.ToolTip="Up to parent folder">
                                <AppBarButton.Icon>
                                    <SymbolIcon Symbol="Up" />
                                </AppBarButton.Icon>
                            </AppBarButton>
                            <TextBlock
                                x:Name="BrowserCurrentPathText"
                                Grid.Column="1"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <TreeView
                            x:Name="FolderTree"
                            Grid.Row="1"
                            MinHeight="80"
                            Expanding="FolderTree_OnExpanding"
                            SelectionChanged="FolderTree_SelectionChanged" />
                    </Grid>
                    <Border
                        x:Name="SplitterBrowserPreview"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                        PointerPressed="SplitterBrowserPreview_PointerPressed"
                        PointerMoved="SplitterBrowserPreview_PointerMoved"
                        PointerReleased="SplitterBrowserPreview_PointerReleased"
                        PointerCaptureLost="Splitter_PointerCaptureLost" />
                    <Grid
                        x:Name="PreviewHostGrid"
                        Grid.Column="2"
                        Margin="8,0"
                        Background="Transparent">
                        <ScrollViewer
                            x:Name="PreviewScrollViewer"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            ZoomMode="Disabled">
                            <Grid
                                x:Name="PreviewScrollContentGrid"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                                <Image
                                    x:Name="PreviewImage"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Stretch="Uniform" />
                            </Grid>
                        </ScrollViewer>
                        <Border
                            x:Name="NormalPathOverlay"
                            Margin="8"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#99000000"
                            CornerRadius="4"
                            Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock
                                    x:Name="NormalPathText"
                                    Foreground="White"
                                    FontSize="12"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    x:Name="NormalPathPositionText"
                                    Foreground="White"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed" />
                                <SymbolIcon
                                    x:Name="NormalPathFlagIcon"
                                    Height="14"
                                    Width="14"
                                    Visibility="Collapsed" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
        <Grid
            x:Name="FullscreenLayout"
            Visibility="Collapsed"
            Background="Black"
            KeyDown="FullscreenLayout_KeyDown"
            IsTabStop="True">
            <Image
                x:Name="FullscreenImage"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Stretch="Uniform" />
            <Border
                x:Name="FullscreenPathOverlay"
                Margin="12"
                Padding="10,6"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#99000000"
                CornerRadius="4"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        x:Name="FullscreenPathText"
                        Foreground="White"
                        FontSize="12"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        x:Name="FullscreenPathPositionText"
                        Foreground="White"
                        FontSize="12"
                        VerticalAlignment="Center"
                        Visibility="Collapsed" />
                    <SymbolIcon
                        x:Name="FullscreenPathFlagIcon"
                        Height="14"
                        Width="14"
                        Visibility="Collapsed" />
                </StackPanel>
            </Border>
            <Border
                x:Name="FullscreenScopeBadgeHost"
                Margin="12"
                Padding="8,4"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#99000000"
                CornerRadius="4"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="FullscreenScopeBadge"
                    Foreground="White"
                    FontSize="12"
                    FontWeight="SemiBold" />
            </Border>
        </Grid>
    </Grid>
</Window>
