<UserControl
    x:Class="ImageHoard.App.HotkeysEditorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid x:Name="RootLayout" MinHeight="240">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            x:Name="HeaderTextBlock"
            Grid.Row="0"
            Margin="0,0,0,8"
            TextWrapping="Wrap"
            Opacity="0.85"
            Text="Bindings merge with shipped keyboard and mouse defaults. Save writes only overrides that differ from those defaults. Enter adds another shortcut variant; Shift+Enter replaces all variants for that row with the next capture. Backspace or Delete removes the selected shortcut variant (or all variants touched by the selection). Escape cancels recording. Mouse: you can hold one or more buttons and scroll the wheel to capture combinations (for example X1 and wheel up)." />
        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="RowHost" Margin="0,0,8,0" />
            </ScrollViewer>
            <Button
                x:Name="CaptureFocusSink"
                Width="1"
                Height="1"
                Margin="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Opacity="0"
                IsTabStop="True"
                KeyDown="CaptureFocusSink_KeyDown" />
        </Grid>
        <TextBlock
            x:Name="StatusText"
            Grid.Row="2"
            Margin="0,8,0,4"
            TextWrapping="Wrap" />
        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Padding="0,8,0,0">
            <Button
                x:Name="SaveButton"
                Content="Save"
                MinWidth="100"
                Margin="0,0,8,0"
                Click="SaveButton_Click" />
            <Button
                x:Name="CancelButton"
                Content="Cancel"
                MinWidth="100"
                Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</UserControl>
