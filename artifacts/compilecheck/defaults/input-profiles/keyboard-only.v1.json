{
  "schemaVersion": 1,
  "profileId": "KeyboardOnly",
  "displayName": "Keyboard-only (sort / browse / slideshow)",
  "description": "Default profile for FR-SR-02 keyboard-only acceptance and FR-IN-02. No mouse bindings required for core commands.",
  "bindings": {
    "nav.nextImage": [
      { "kind": "keyboard", "keys": ["ArrowRight"] },
      { "kind": "keyboard", "keys": ["ArrowDown"] },
      { "kind": "keyboard", "keys": ["Space"] }
    ],
    "nav.prevImage": [
      { "kind": "keyboard", "keys": ["ArrowLeft"] },
      { "kind": "keyboard", "keys": ["ArrowUp"] },
      { "kind": "keyboard", "keys": ["Backspace"] }
    ],
    "nav.firstImage": [{ "kind": "keyboard", "keys": ["Home"] }],
    "nav.lastImage": [{ "kind": "keyboard", "keys": ["End"] }],
    "nav.nextDirectory": [{ "kind": "keyboard", "keys": ["Control", "Alt", "PageDown"] }],
    "nav.prevDirectory": [{ "kind": "keyboard", "keys": ["Control", "Alt", "PageUp"] }],
    "nav.cycleNavigationMode": [{ "kind": "keyboard", "keys": ["Control", "Shift", "KeyN"] }],
    "sort.flagKeep": [{ "kind": "keyboard", "keys": ["KeyK"] }],
    "sort.flagDelete": [{ "kind": "keyboard", "keys": ["KeyD"] }],
    "sort.flagUnset": [{ "kind": "keyboard", "keys": ["KeyU"] }],
    "sort.deleteArchiveWizard": [
      { "kind": "keyboard", "keys": ["Control", "Shift", "Delete"] },
      { "kind": "keyboard", "keys": ["Control", "Shift", "KeyM"] }
    ],
    "sort.clearAllFlags": [{ "kind": "keyboard", "keys": ["Control", "KeyZ"] }],
    "slideshow.start": [{ "kind": "keyboard", "keys": ["Control", "Shift", "KeyS"] }],
    "slideshow.toggleScope": [{ "kind": "keyboard", "keys": ["Tab"] }],
    "ui.fullscreen": [
      { "kind": "keyboard", "keys": ["F11"] },
      { "kind": "keyboard", "keys": ["Enter"] }
    ],
    "view.clearSelection": [{ "kind": "keyboard", "keys": ["Escape"] }]
  }
}
