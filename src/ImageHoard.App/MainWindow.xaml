<Window
    x:Class="ImageHoard.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ImageHoard.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ImageHoard">
    <Grid
        x:Name="RootGrid"
        KeyDown="RootGrid_KeyDown"
        IsTabStop="True">
        <Grid.Resources>
            <local:BoolToVisibilityConverter x:Key="BoolToVis" />
            <local:InvertedBoolToVisibilityConverter x:Key="InvBoolToVis" />
            <DataTemplate x:Key="BrowserFolderItemTemplate">
                <Grid
                    MinHeight="22"
                    Padding="0"
                    DataContext="{Binding Content}"
                    RightTapped="BrowserTreeRow_RightTapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        ColumnSpacing="10"
                        Visibility="{Binding IsRenaming, Converter={StaticResource InvBoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{Binding DisplayLabel}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            MinWidth="56"
                            TextAlignment="Right"
                            Text="{Binding SizeDisplay}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{Binding SizeDetailVisibility}" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            MinWidth="48"
                            TextAlignment="Right"
                            Text="{Binding ImageCountDisplay}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{Binding ImageCountDetailVisibility}" />
                        <TextBlock
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            MinWidth="120"
                            Text="{Binding ModifiedDisplay}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{Binding DateDetailVisibility}" />
                    </Grid>
                    <TextBox
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        VerticalAlignment="Center"
                        Text="{Binding EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}}"
                        PreviewKeyDown="BrowserRenameTextBox_PreviewKeyDown"
                        LostFocus="BrowserRenameTextBox_LostFocus"
                        Loaded="BrowserRenameTextBox_Loaded" />
                </Grid>
            </DataTemplate>
            <DataTemplate x:Key="BrowserFileItemTemplate">
                <Grid
                    MinHeight="22"
                    Padding="0"
                    DataContext="{Binding Content}"
                    RightTapped="BrowserTreeRow_RightTapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        ColumnSpacing="10"
                        Visibility="{Binding IsRenaming, Converter={StaticResource InvBoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <SymbolIcon
                                Grid.Column="0"
                                Width="14"
                                Height="14"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Symbol="{Binding SortFlagGlyphSymbol}"
                                Foreground="{Binding SortFlagGlyphForeground}"
                                Visibility="{Binding SortFlagGlyphVisibility}" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="{Binding DisplayName}"
                                TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            MinWidth="56"
                            TextAlignment="Right"
                            Text="{Binding SizeDisplay}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{Binding SizeDetailVisibility}" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            MinWidth="120"
                            Text="{Binding ModifiedDisplay}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{Binding DateDetailVisibility}" />
                    </Grid>
                    <TextBox
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        VerticalAlignment="Center"
                        Text="{Binding EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}}"
                        PreviewKeyDown="BrowserRenameTextBox_PreviewKeyDown"
                        LostFocus="BrowserRenameTextBox_LostFocus"
                        Loaded="BrowserRenameTextBox_Loaded" />
                </Grid>
            </DataTemplate>
            <DataTemplate x:Key="BrowserFileListHeaderTemplate">
                <Grid MinHeight="18" Padding="0,0,0,2" ColumnSpacing="10" DataContext="{Binding Content}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Opacity="0.9"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Name" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        MinWidth="56"
                        TextAlignment="Right"
                        Opacity="0.9"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Size"
                        Visibility="{Binding SizeHeaderVisibility}" />
                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        MinWidth="120"
                        Opacity="0.9"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Date modified"
                        Visibility="{Binding DateHeaderVisibility}" />
                </Grid>
            </DataTemplate>
            <DataTemplate x:Key="BrowserFolderListHeaderTemplate">
                <Grid MinHeight="18" Padding="0,0,0,2" ColumnSpacing="10" DataContext="{Binding Content}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="0"
                        Padding="0,0,4,0"
                        HorizontalContentAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="FolderBrowserHeaderSort_Name_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                Opacity="0.9"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Name" />
                            <TextBlock
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Opacity="0.75"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="▼"
                                Visibility="{Binding NameSortIndicatorVisibility}" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Column="1"
                        Padding="4,0,4,0"
                        HorizontalContentAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="FolderBrowserHeaderSort_Size_Click"
                        Visibility="{Binding SizeHeaderVisibility}">
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <TextBlock
                                MinWidth="56"
                                TextAlignment="Right"
                                VerticalAlignment="Center"
                                Opacity="0.9"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Size" />
                            <TextBlock
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Opacity="0.75"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="▼"
                                Visibility="{Binding SizeSortIndicatorVisibility}" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Column="2"
                        Padding="4,0,4,0"
                        HorizontalContentAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="FolderBrowserHeaderSort_ImageCount_Click"
                        Visibility="{Binding ImageCountHeaderVisibility}">
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <TextBlock
                                MinWidth="48"
                                TextAlignment="Right"
                                VerticalAlignment="Center"
                                Opacity="0.9"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Images" />
                            <TextBlock
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Opacity="0.75"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="▼"
                                Visibility="{Binding ImageCountSortIndicatorVisibility}" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Column="3"
                        Padding="4,0,0,0"
                        HorizontalContentAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="FolderBrowserHeaderSort_Date_Click"
                        Visibility="{Binding DateHeaderVisibility}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                MinWidth="120"
                                VerticalAlignment="Center"
                                Opacity="0.9"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Date modified" />
                            <TextBlock
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Opacity="0.75"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="▼"
                                Visibility="{Binding DateSortIndicatorVisibility}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </DataTemplate>
        </Grid.Resources>
        <Grid x:Name="NormalLayout" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="160" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <MenuBar Grid.Row="0">
                <MenuBarItem Title="File">
                    <MenuFlyoutItem Text="Open folder…" Click="OpenFolder_Click" />
                    <MenuFlyoutSubItem x:Name="FileFavoritesSubMenu" Text="Favorites" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Exit" Click="Exit_Click" />
                </MenuBarItem>
                <MenuBarItem Title="View">
                    <ToggleMenuFlyoutItem
                        x:Name="ShowBrowserPaneToggle"
                        Text="Show browser pane"
                        Click="ShowBrowserPaneToggle_Click" />
                    <ToggleMenuFlyoutItem
                        x:Name="IncludeSubfoldersToggle"
                        Text="Include subfolders in list"
                        Click="IncludeSubfoldersToggle_Click" />
                    <MenuFlyoutSubItem Text="File details">
                        <ToggleMenuFlyoutItem
                            x:Name="ShowBrowserFileColumnHeadingsToggle"
                            Text="Show column headings"
                            Click="ShowBrowserFileColumnHeadingsToggle_Click" />
                        <ToggleMenuFlyoutItem
                            x:Name="ShowBrowserFileSizeToggle"
                            Text="Show file size"
                            Click="ShowBrowserFileSizeToggle_Click" />
                        <ToggleMenuFlyoutItem
                            x:Name="ShowBrowserFileDateToggle"
                            Text="Show date modified"
                            Click="ShowBrowserFileDateToggle_Click" />
                        <MenuFlyoutSeparator />
                        <RadioMenuFlyoutItem
                            x:Name="SortNameNaturalItem"
                            Text="Name (natural order)"
                            GroupName="ListSort"
                            Click="SortList_NameNatural_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="SortNameItem"
                            Text="Name (A–Z only)"
                            GroupName="ListSort"
                            Click="SortList_Name_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="SortDateItem"
                            Text="Date modified"
                            GroupName="ListSort"
                            Click="SortList_Date_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="SortSizeItem"
                            Text="Size"
                            GroupName="ListSort"
                            Click="SortList_Size_Click" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSubItem Text="Folder details">
                        <ToggleMenuFlyoutItem
                            x:Name="ShowBrowserFolderColumnHeadingsToggle"
                            Text="Show column headings"
                            Click="ShowBrowserFolderColumnHeadingsToggle_Click" />
                        <ToggleMenuFlyoutItem
                            x:Name="ShowBrowserFolderDateToggle"
                            Text="Show date modified"
                            Click="ShowBrowserFolderDateToggle_Click" />
                        <ToggleMenuFlyoutItem
                            x:Name="ShowBrowserFolderSizeToggle"
                            Text="Show folder size"
                            Click="ShowBrowserFolderSizeToggle_Click" />
                        <ToggleMenuFlyoutItem
                            x:Name="ShowBrowserFolderImageCountToggle"
                            Text="Show image count"
                            Click="ShowBrowserFolderImageCountToggle_Click" />
                        <MenuFlyoutSeparator />
                        <RadioMenuFlyoutItem
                            x:Name="FolderSortNameNaturalItem"
                            Text="Name (natural order)"
                            GroupName="FolderListSort"
                            Click="FolderSortMenu_NameNatural_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="FolderSortDateItem"
                            Text="Date modified"
                            GroupName="FolderListSort"
                            Click="FolderSortMenu_DateModified_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="FolderSortTotalSizeItem"
                            Text="Total size"
                            GroupName="FolderListSort"
                            Click="FolderSortMenu_TotalSize_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="FolderSortImageCountItem"
                            Text="Image count"
                            GroupName="FolderListSort"
                            Click="FolderSortMenu_ImageCount_Click" />
                    </MenuFlyoutSubItem>
                </MenuBarItem>
                <MenuBarItem Title="Browse">
                    <MenuFlyoutSubItem Text="Navigation mode">
                        <MenuFlyoutSubItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="N" Modifiers="Control,Shift" />
                        </MenuFlyoutSubItem.KeyboardAccelerators>
                        <RadioMenuFlyoutItem
                            x:Name="BrowseNavModeAllItem"
                            Text="All images in folder"
                            GroupName="BrowseNavigationMode"
                            Click="BrowseNavModeAll_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="BrowseNavModeKeepItem"
                            Text="Only images flagged Keep"
                            GroupName="BrowseNavigationMode"
                            Click="BrowseNavModeKeep_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="BrowseNavModeNotKeepItem"
                            Text="Only images not flagged Keep"
                            GroupName="BrowseNavigationMode"
                            Click="BrowseNavModeNotKeep_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="BrowseNavModeUnflaggedItem"
                            Text="Only unflagged images"
                            GroupName="BrowseNavigationMode"
                            Click="BrowseNavModeUnflagged_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="BrowseNavModeDeleteItem"
                            Text="Only images flagged Delete"
                            GroupName="BrowseNavigationMode"
                            Click="BrowseNavModeDelete_Click" />
                    </MenuFlyoutSubItem>
                </MenuBarItem>
                <MenuBarItem Title="Sort">
                    <MenuFlyoutItem Text="Clear all flags" Click="SortClearAllFlags_Click" />
                </MenuBarItem>
                <MenuBarItem Title="Image">
                    <MenuFlyoutSubItem Text="Info overlay">
                        <ToggleMenuFlyoutItem
                            x:Name="ShowPathOnOverlayWindowedToggle"
                            Text="Show file path (windowed preview)"
                            Click="ShowPathOnOverlayWindowedToggle_Click" />
                        <ToggleMenuFlyoutItem
                            x:Name="ShowPathOnOverlayFullscreenToggle"
                            Text="Show file path (fullscreen)"
                            Click="ShowPathOnOverlayFullscreenToggle_Click" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSubItem Text="Image fit">
                        <RadioMenuFlyoutItem
                            x:Name="FitModeFitItem"
                            Text="Fit"
                            GroupName="ImageFit"
                            Click="ViewFit_Fit_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="FitModeFillItem"
                            Text="Fill"
                            GroupName="ImageFit"
                            Click="ViewFit_Fill_Click" />
                        <RadioMenuFlyoutItem
                            x:Name="FitModeOneToOneItem"
                            Text="1:1"
                            GroupName="ImageFit"
                            Click="ViewFit_OneToOne_Click" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        x:Name="EnterFullscreenMenuItem"
                        Text="Enter fullscreen"
                        Click="EnterFullscreen_Click" />
                </MenuBarItem>
                <MenuBarItem Title="Settings">
                    <MenuFlyoutItem Text="Preferences…" Click="OptionsPreferences_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Clear caches (metrics)" Click="SettingsClearCaches_Click" />
                    <MenuFlyoutItem Text="Clear caches + operation log" Click="SettingsClearCachesAndLog_Click" />
                    <MenuFlyoutItem Text="About random fairness…" Click="SlideshowFairnessHelp_Click" />
                </MenuBarItem>
            </MenuBar>
            <Grid x:Name="ContentBelowMenu" Grid.Row="1" MinHeight="160">
                <Grid x:Name="BrowserPaneGrid" MinHeight="120">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="ColBrowser" MinWidth="120" Width="74*" />
                        <ColumnDefinition x:Name="ColGapBrowserPreview" Width="6" />
                        <ColumnDefinition x:Name="ColPreview" MinWidth="120" Width="26*" />
                    </Grid.ColumnDefinitions>
                    <Grid
                        x:Name="BrowserColumnHost"
                        Grid.Column="0"
                        MinWidth="120">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="80" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid
                            Grid.Row="0"
                            MinHeight="36"
                            Padding="0,4,0,4"
                            ColumnSpacing="4"
                            RightTapped="BrowserBrowseToolbar_RightTapped">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <AppBarButton
                                x:Name="BrowserNavigateUpButton"
                                Grid.Column="0"
                                Width="40"
                                Height="36"
                                IsCompact="True"
                                VerticalAlignment="Center"
                                LabelPosition="Collapsed"
                                Click="BrowserNavigateUp_Click"
                                ToolTipService.ToolTip="Up to parent folder">
                                <AppBarButton.Icon>
                                    <SymbolIcon Symbol="Up" />
                                </AppBarButton.Icon>
                            </AppBarButton>
                            <TextBlock
                                x:Name="BrowserCurrentPathText"
                                Grid.Column="1"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <TreeView
                            x:Name="FolderTree"
                            Grid.Row="1"
                            MinHeight="80"
                            Collapsed="FolderTree_OnCollapsed"
                            Expanding="FolderTree_OnExpanding"
                            SelectionChanged="FolderTree_SelectionChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="MinHeight" Value="22" />
                                    <Setter Property="Padding" Value="0,0,0,0" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                        <Grid
                            Grid.Row="2"
                            MinHeight="32"
                            Padding="0,4,0,4"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0">
                            <Button
                                x:Name="ArchiveTargetBrowserRowButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="4,0"
                                Click="ArchiveTargetBrowserRow_Click">
                                <TextBlock
                                    x:Name="ArchiveTargetBrowserPathText"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis" />
                            </Button>
                        </Grid>
                    </Grid>
                    <local:BrowserPreviewSplitterGrid
                        x:Name="SplitterBrowserPreview"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                        PointerPressed="SplitterBrowserPreview_PointerPressed"
                        PointerMoved="SplitterBrowserPreview_PointerMoved"
                        PointerReleased="SplitterBrowserPreview_PointerReleased"
                        PointerCaptureLost="Splitter_PointerCaptureLost" />
                    <Grid
                        x:Name="PreviewHostGrid"
                        Grid.Column="2"
                        Margin="8,0"
                        Background="Transparent">
                        <ScrollViewer
                            x:Name="PreviewScrollViewer"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            ZoomMode="Disabled">
                            <Grid
                                x:Name="PreviewScrollContentGrid"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                                <Image
                                    x:Name="PreviewImage"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Stretch="Uniform" />
                            </Grid>
                        </ScrollViewer>
                        <Border
                            x:Name="NormalPathOverlay"
                            Margin="8"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#99000000"
                            CornerRadius="4"
                            Visibility="Collapsed">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock
                                        x:Name="NormalPathText"
                                        Foreground="White"
                                        FontSize="12"
                                        TextWrapping="WrapWholeWords" />
                                    <TextBlock
                                        x:Name="NormalPathPositionText"
                                        Foreground="White"
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed" />
                                    <SymbolIcon
                                        x:Name="NormalPathFlagIcon"
                                        Height="14"
                                        Width="14"
                                        Visibility="Collapsed" />
                                </StackPanel>
                                <TextBlock
                                    x:Name="NormalNavigationModeText"
                                    Foreground="White"
                                    FontSize="12"
                                    Opacity="0.95"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="NormalArchiveDestExistsText"
                                    FontSize="12"
                                    TextWrapping="WrapWholeWords"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="NormalArchiveSubfolderText"
                                    FontSize="12"
                                    TextWrapping="WrapWholeWords"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="NormalArchiveConflictText"
                                    FontSize="12"
                                    TextWrapping="WrapWholeWords"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="NormalArchiveIdenticalSummaryText"
                                    FontSize="12"
                                    TextWrapping="WrapWholeWords"
                                    Visibility="Collapsed" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
            <Border
                Grid.Row="2"
                Padding="8,4"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                <TextBlock
                    x:Name="TransientStatusText"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    TextWrapping="WrapWholeWords"
                    Opacity="0.95" />
            </Border>
        </Grid>
        <Grid
            x:Name="FullscreenLayout"
            Visibility="Collapsed"
            Background="Black"
            KeyDown="FullscreenLayout_KeyDown"
            IsTabStop="True">
            <Image
                x:Name="FullscreenImage"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Stretch="Uniform" />
            <Border
                x:Name="FullscreenPathOverlay"
                Margin="12"
                Padding="10,6"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#99000000"
                CornerRadius="4"
                Visibility="Collapsed">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            x:Name="FullscreenPathText"
                            Foreground="White"
                            FontSize="12"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            x:Name="FullscreenPathPositionText"
                            Foreground="White"
                            FontSize="12"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                        <SymbolIcon
                            x:Name="FullscreenPathFlagIcon"
                            Height="14"
                            Width="14"
                            Visibility="Collapsed" />
                    </StackPanel>
                    <TextBlock
                        x:Name="FullscreenNavigationModeText"
                        Foreground="White"
                        FontSize="12"
                        Opacity="0.95"
                        Visibility="Collapsed" />
                    <TextBlock
                        x:Name="FullscreenArchiveDestExistsText"
                        FontSize="12"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                    <TextBlock
                        x:Name="FullscreenArchiveSubfolderText"
                        FontSize="12"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                    <TextBlock
                        x:Name="FullscreenArchiveConflictText"
                        FontSize="12"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                    <TextBlock
                        x:Name="FullscreenArchiveIdenticalSummaryText"
                        FontSize="12"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                </StackPanel>
            </Border>
            <Border
                x:Name="FullscreenScopeBadgeHost"
                Margin="12"
                Padding="8,4"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#99000000"
                CornerRadius="4"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="FullscreenScopeBadge"
                    Foreground="White"
                    FontSize="12"
                    FontWeight="SemiBold" />
            </Border>
        </Grid>
        <Grid
            x:Name="DeleteArchiveWizardOverlayRoot"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#B3000000"
            IsHitTestVisible="True"
            IsTabStop="True"
            PreviewKeyDown="DeleteArchiveWizardOverlayRoot_PreviewKeyDown"
            Visibility="Collapsed">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="440"
                MaxHeight="680"
                Margin="24"
                Padding="0"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <local:DeleteArchiveWizardPanel x:Name="DeleteArchiveWizardPanelElement" />
            </Border>
        </Grid>
        <Grid
            x:Name="PreferencesOverlayRoot"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#B3000000"
            IsHitTestVisible="True"
            IsTabStop="True"
            PreviewKeyDown="PreferencesOverlayRoot_PreviewKeyDown"
            Visibility="Collapsed">
            <Grid
                MaxWidth="960"
                MaxHeight="720"
                Margin="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Padding="0,0,0,8">
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="Preferences" />
                    <Button
                        HorizontalAlignment="Right"
                        Click="PreferencesOverlayClose_Click"
                        Content="Close" />
                </Grid>
                <Border
                    Grid.Row="1"
                    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <local:PreferencesPanel x:Name="PreferencesPanelElement" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
