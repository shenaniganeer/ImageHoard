<UserControl
    x:Class="ImageHoard.App.PreferencesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageHoard.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <NavigationView
        x:Name="RootNav"
        PaneDisplayMode="Left"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        Loaded="RootNav_Loaded"
        SelectionChanged="RootNav_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="NavItemHotkeys" Content="Hotkeys" Tag="hotkeys" />
            <NavigationViewItem x:Name="NavItemAdvanced" Content="Advanced" Tag="advanced" />
        </NavigationView.MenuItems>
        <Grid
            x:Name="PagesHost"
            MinWidth="752"
            MinHeight="752"
            Padding="16,8,16,16">
            <ScrollViewer
                x:Name="PageAdvanced"
                VerticalAlignment="Stretch"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Visibility="Collapsed">
                <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Advanced" />
                    <TextBlock
                        Margin="0,8,0,16"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Archive destination, caches, and preview navigation tuning. Other layout and overlay options are under the View and Image menus." />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontWeight="SemiBold"
                        Text="Library" />
                    <TextBlock
                        Margin="0,0,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Archive destination and caches." />
                    <TextBlock Text="Archive target folder" />
                    <TextBlock
                        x:Name="ArchiveRootDisplay"
                        Margin="0,4,0,8"
                        TextWrapping="Wrap"
                        IsTextSelectionEnabled="True" />
                    <Button
                        Content="Select archive target folder"
                        HorizontalAlignment="Left"
                        Click="SetArchiveRoot_Click" />
                    <TextBlock Margin="0,24,0,8" Text="Caches" />
                    <Button
                        Content="Clear caches (metrics)"
                        HorizontalAlignment="Left"
                        Click="ClearCaches_Click" />
                    <Button
                        Margin="0,8,0,0"
                        Content="Clear caches + operation log"
                        HorizontalAlignment="Left"
                        Click="ClearCachesAndLog_Click" />
                    <TextBlock
                        Margin="0,24,0,4"
                        FontWeight="SemiBold"
                        Text="Preview" />
                    <TextBlock
                        Margin="0,0,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="When stepping quickly through images, each step is shown in order until the queue falls behind; then only the latest image is decoded. Set to 0 to never skip queued steps (full FIFO). Higher values allow skipping only after the backlog has waited longer." />
                    <NumberBox
                        x:Name="PreviewNavCatchUpLagNumberBox"
                        Header="Rapid navigation catch-up (seconds)"
                        Minimum="0"
                        Maximum="5"
                        SmallChange="0.1"
                        LargeChange="0.5"
                        SpinButtonPlacementMode="Inline"
                        ValueChanged="PreviewNavCatchUpLagNumberBox_ValueChanged" />
                    <TextBlock
                        Margin="0,16,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="When more images are queued, each stays on screen at least this long before the next decode. Set to 0 to show the next image as soon as it is ready." />
                    <NumberBox
                        x:Name="PreviewMinimumDisplayNumberBox"
                        Header="Minimum image display time (seconds)"
                        Minimum="0"
                        Maximum="5"
                        SmallChange="0.05"
                        LargeChange="0.25"
                        SpinButtonPlacementMode="Inline"
                        ValueChanged="PreviewMinimumDisplayNumberBox_ValueChanged" />
                    <TextBlock
                        Margin="0,16,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Maximum time between mouse presses for double-click and triple-click chords that are bound to the image preview (windowed or fullscreen), for example first or last image in the current folder. Use 0 for the Windows default. Does not change folder tree double-click behavior." />
                    <NumberBox
                        x:Name="PreviewImagePaneMultiClickThresholdNumberBox"
                        Header="Image preview multi-click threshold (ms)"
                        Minimum="0"
                        Maximum="2000"
                        SmallChange="10"
                        LargeChange="50"
                        SpinButtonPlacementMode="Inline"
                        ValueChanged="PreviewImagePaneMultiClickThresholdNumberBox_ValueChanged" />
                    <TextBlock
                        Margin="0,16,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Zoom in and zoom out multiply the current preview scale by this value each step (for example 1.1 is about a 10% change per step)." />
                    <NumberBox
                        x:Name="PreviewZoomStepRatioNumberBox"
                        Header="Preview zoom step (multiplier)"
                        Minimum="1.01"
                        Maximum="2"
                        SmallChange="0.01"
                        LargeChange="0.05"
                        SpinButtonPlacementMode="Inline"
                        ValueChanged="PreviewZoomStepRatioNumberBox_ValueChanged" />
                </StackPanel>
            </ScrollViewer>
            <Grid
                x:Name="PageHotkeys"
                VerticalAlignment="Stretch"
                Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Hotkeys" />
                <TextBlock
                    Grid.Row="1"
                    Margin="0,8,0,8"
                    MaxWidth="720"
                    HorizontalAlignment="Left"
                    TextWrapping="Wrap"
                    Opacity="0.7"
                    Text="Edit shortcuts below; changes save immediately. Only your differences from shipped defaults are written to disk. Use Reset to Defaults on the Hotkeys page to restore all shipped shortcuts." />
                <TextBlock
                    x:Name="HotkeysLoadError"
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    MaxWidth="720"
                    HorizontalAlignment="Left"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Visibility="Collapsed"
                    Text="Could not load keyboard and mouse profile. Try again after closing and reopening Preferences." />
                <local:HotkeysEditorControl
                    x:Name="HotkeysEditor"
                    Grid.Row="2"
                    MaxWidth="720"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch" />
            </Grid>
        </Grid>
    </NavigationView>
</UserControl>
