<UserControl
    x:Class="ImageHoard.App.PreferencesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageHoard.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <NavigationView
        x:Name="RootNav"
        PaneDisplayMode="Left"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        Loaded="RootNav_Loaded"
        SelectionChanged="RootNav_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="NavItemGeneral" Content="General" Tag="general" />
            <NavigationViewItem x:Name="NavItemHotkeys" Content="Hotkeys" Tag="hotkeys" />
            <NavigationViewItem Content="Library" Tag="library" />
        </NavigationView.MenuItems>
        <Grid x:Name="PagesHost" Padding="16,8,16,16">
            <ScrollViewer
                x:Name="PageGeneral"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Visibility="Visible">
                <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="General" />
                    <TextBlock
                        Margin="0,8,0,16"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Layout, browsing, slideshow options, and operation logging." />

                    <TextBlock
                        Margin="0,8,0,4"
                        FontWeight="SemiBold"
                        Text="View" />
                    <TextBlock
                        Margin="0,0,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Layout and how the image list and preview behave." />
                    <ToggleSwitch
                        x:Name="ShowBrowserPaneToggle"
                        Header="Show browser pane"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="ShowBrowserPaneToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="ShowPathOnOverlayWindowedToggle"
                        Margin="0,16,0,0"
                        Header="Show file path on image overlay (windowed preview)"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="ShowPathOnOverlayWindowedToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="ShowPathOnOverlayFullscreenToggle"
                        Margin="0,16,0,0"
                        Header="Show file path on image overlay (fullscreen)"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="ShowPathOnOverlayFullscreenToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="ShowOverlayListPositionToggle"
                        Margin="0,16,0,0"
                        Header="Show list position on image overlay"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="ShowOverlayListPositionToggle_Toggled" />
                    <TextBlock
                        Margin="0,4,0,0"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="When on, shows position on the overlay: in browse mode, index and total in the current file list (e.g. 2/78). In tree slideshow, slide number and history length plus how many paths have been discovered (e.g. 3/12 · discovered 45,210)." />
                    <TextBlock
                        Margin="0,16,0,4"
                        FontWeight="SemiBold"
                        Text="Preview" />
                    <TextBlock
                        Margin="0,0,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="When stepping quickly through images, each step is shown in order until the queue falls behind; then only the latest image is decoded. Set to 0 to never skip queued steps (full FIFO). Higher values allow skipping only after the backlog has waited longer." />
                    <NumberBox
                        x:Name="PreviewNavCatchUpLagNumberBox"
                        Header="Rapid navigation catch-up (seconds)"
                        Minimum="0"
                        Maximum="5"
                        SmallChange="0.1"
                        LargeChange="0.5"
                        SpinButtonPlacementMode="Inline"
                        ValueChanged="PreviewNavCatchUpLagNumberBox_ValueChanged" />
                    <TextBlock Margin="0,16,0,8" Text="Default list sort" />
                    <StackPanel>
                        <RadioButton
                            x:Name="SortNameNaturalRadio"
                            GroupName="PrefListSort"
                            Content="Name (natural order)"
                            Checked="SortRadio_Checked" />
                        <RadioButton
                            x:Name="SortNameRadio"
                            GroupName="PrefListSort"
                            Content="Name (A–Z only)"
                            Checked="SortRadio_Checked" />
                        <RadioButton
                            x:Name="SortDateRadio"
                            GroupName="PrefListSort"
                            Content="Date modified"
                            Checked="SortRadio_Checked" />
                        <RadioButton
                            x:Name="SortSizeRadio"
                            GroupName="PrefListSort"
                            Content="Size"
                            Checked="SortRadio_Checked" />
                    </StackPanel>

                    <TextBlock
                        Margin="0,24,0,4"
                        FontWeight="SemiBold"
                        Text="Browse" />
                    <TextBlock
                        Margin="0,0,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="How folders and file lists are enumerated." />
                    <ToggleSwitch
                        x:Name="IncludeSubfoldersToggle"
                        Header="Include subfolders in file list"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="IncludeSubfoldersToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="CollectFolderStatisticsInBackgroundToggle"
                        Margin="0,16,0,0"
                        Header="Collect folder statistics in background"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="CollectFolderStatisticsInBackgroundToggle_Toggled" />
                    <TextBlock
                        Margin="0,4,0,0"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="When on, folder size and image count can update asynchronously while browsing (if those columns are shown under View → Folder details)." />

                    <TextBlock
                        Margin="0,24,0,4"
                        FontWeight="SemiBold"
                        Text="Slideshow" />
                    <TextBlock
                        Margin="0,0,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Slideshow-specific behavior (some options apply when delete-from-slideshow is wired)." />
                    <ToggleSwitch
                        x:Name="SlideshowAllowDeleteToggle"
                        Header="Allow delete in slideshow"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="SlideshowAllowDeleteToggle_Toggled" />
                    <TextBlock
                        Margin="0,4,0,0"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Saved for future use with the slideshow delete command; shortcuts are edited under Preferences → Hotkeys." />

                    <TextBlock
                        Margin="0,24,0,4"
                        FontWeight="SemiBold"
                        Text="Destructive operations" />
                    <ToggleSwitch
                        x:Name="LogOperationsToggle"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="LogOperationsToggle_Toggled" />
                    <TextBlock
                        Margin="0,4,0,0"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="When on, batch delete and move-to-archive write JSON lines to the operation log (if enabled in Settings)." />
                </StackPanel>
            </ScrollViewer>
            <Grid
                x:Name="PageHotkeys"
                VerticalAlignment="Stretch"
                Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Hotkeys" />
                <TextBlock
                    Grid.Row="1"
                    Margin="0,8,0,8"
                    MaxWidth="720"
                    HorizontalAlignment="Left"
                    TextWrapping="Wrap"
                    Opacity="0.7"
                    Text="Edit shortcuts below. Only your differences from shipped defaults are saved to disk." />
                <TextBlock
                    x:Name="HotkeysLoadError"
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    MaxWidth="720"
                    HorizontalAlignment="Left"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Visibility="Collapsed"
                    Text="Could not load keyboard and mouse profile. Try again after closing and reopening Preferences." />
                <local:HotkeysEditorControl
                    x:Name="HotkeysEditor"
                    Grid.Row="2"
                    MaxWidth="720"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch" />
            </Grid>
            <ScrollViewer
                x:Name="PageLibrary"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Visibility="Collapsed">
                <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Library" />
                    <TextBlock
                        Margin="0,8,0,16"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Archive destination and caches." />
                    <TextBlock Text="Archive target folder" />
                    <TextBlock
                        x:Name="ArchiveRootDisplay"
                        Margin="0,4,0,8"
                        TextWrapping="Wrap"
                        IsTextSelectionEnabled="True" />
                    <Button
                        Content="Select archive target folder"
                        HorizontalAlignment="Left"
                        Click="SetArchiveRoot_Click" />
                    <TextBlock Margin="0,24,0,8" Text="Caches" />
                    <Button
                        Content="Clear caches (metrics)"
                        HorizontalAlignment="Left"
                        Click="ClearCaches_Click" />
                    <Button
                        Margin="0,8,0,0"
                        Content="Clear caches + operation log"
                        HorizontalAlignment="Left"
                        Click="ClearCachesAndLog_Click" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </NavigationView>
</UserControl>
