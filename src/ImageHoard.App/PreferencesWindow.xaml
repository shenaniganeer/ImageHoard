<Window
    x:Class="ImageHoard.App.PreferencesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Preferences">
    <NavigationView
        x:Name="RootNav"
        PaneDisplayMode="Left"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        Loaded="RootNav_Loaded"
        SelectionChanged="RootNav_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="NavItemGeneral" Content="General" Tag="general" />
            <NavigationViewItem x:Name="NavItemHotkeys" Content="Hotkeys" Tag="hotkeys" />
            <NavigationViewItem Content="Library" Tag="library" />
        </NavigationView.MenuItems>
        <Grid x:Name="PagesHost" Padding="0,8,16,16">
            <ScrollViewer
                x:Name="PageGeneral"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Visibility="Visible">
                <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="General" />
                    <TextBlock
                        Margin="0,8,0,16"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Layout, browsing, slideshow options, and operation logging." />

                    <TextBlock
                        Margin="0,8,0,4"
                        FontWeight="SemiBold"
                        Text="View" />
                    <TextBlock
                        Margin="0,0,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Layout and how the image list and preview behave." />
                    <ToggleSwitch
                        x:Name="ShowBrowserPaneToggle"
                        Header="Show browser pane"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="ShowBrowserPaneToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="ShowPathOverlayToggle"
                        Margin="0,16,0,0"
                        Header="Show file path on image overlay (fullscreen)"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="ShowPathOverlayToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="ShowOverlayListPositionToggle"
                        Margin="0,16,0,0"
                        Header="Show list position on image overlay"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="ShowOverlayListPositionToggle_Toggled" />
                    <TextBlock
                        Margin="0,4,0,0"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="When on, shows current index and total in the file list (e.g. 2/78) on the overlay when the image is in that list." />
                    <TextBlock Margin="0,16,0,8" Text="Default list sort" />
                    <StackPanel>
                        <RadioButton
                            x:Name="SortNameNaturalRadio"
                            GroupName="PrefListSort"
                            Content="Name (natural order)"
                            Checked="SortRadio_Checked" />
                        <RadioButton
                            x:Name="SortNameRadio"
                            GroupName="PrefListSort"
                            Content="Name (A–Z only)"
                            Checked="SortRadio_Checked" />
                        <RadioButton
                            x:Name="SortDateRadio"
                            GroupName="PrefListSort"
                            Content="Date modified"
                            Checked="SortRadio_Checked" />
                        <RadioButton
                            x:Name="SortSizeRadio"
                            GroupName="PrefListSort"
                            Content="Size"
                            Checked="SortRadio_Checked" />
                    </StackPanel>

                    <TextBlock
                        Margin="0,24,0,4"
                        FontWeight="SemiBold"
                        Text="Browse" />
                    <TextBlock
                        Margin="0,0,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="How folders and file lists are enumerated." />
                    <ToggleSwitch
                        x:Name="IncludeSubfoldersToggle"
                        Header="Include subfolders in file list"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="IncludeSubfoldersToggle_Toggled" />

                    <TextBlock
                        Margin="0,24,0,4"
                        FontWeight="SemiBold"
                        Text="Slideshow" />
                    <TextBlock
                        Margin="0,0,0,8"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Slideshow-specific behavior (some options apply when delete-from-slideshow is wired)." />
                    <ToggleSwitch
                        x:Name="SlideshowAllowDeleteToggle"
                        Header="Allow delete in slideshow"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="SlideshowAllowDeleteToggle_Toggled" />
                    <TextBlock
                        Margin="0,4,0,0"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Saved for future use with the slideshow delete command; shortcuts are edited under Preferences → Hotkeys." />

                    <TextBlock
                        Margin="0,24,0,4"
                        FontWeight="SemiBold"
                        Text="Destructive operations" />
                    <ToggleSwitch
                        x:Name="LogOperationsToggle"
                        OnContent="On"
                        OffContent="Off"
                        Toggled="LogOperationsToggle_Toggled" />
                    <TextBlock
                        Margin="0,4,0,0"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="When on, batch delete and move-to-archive write JSON lines to the operation log (if enabled in Settings)." />
                </StackPanel>
            </ScrollViewer>
            <ScrollViewer
                x:Name="PageHotkeys"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Visibility="Collapsed">
                <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Hotkeys" />
                    <TextBlock
                        Margin="0,8,0,16"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Customize keyboard, mouse, and wheel shortcuts. Changes merge with shipped defaults; only your differences are saved." />
                    <Button
                        x:Name="EditHotkeysButton"
                        Content="Edit shortcuts…"
                        HorizontalAlignment="Left"
                        Click="EditHotkeysButton_Click" />
                </StackPanel>
            </ScrollViewer>
            <ScrollViewer
                x:Name="PageLibrary"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Visibility="Collapsed">
                <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Library" />
                    <TextBlock
                        Margin="0,8,0,16"
                        TextWrapping="Wrap"
                        Opacity="0.7"
                        Text="Archive destination and caches." />
                    <TextBlock Text="Archive root" />
                    <TextBlock
                        x:Name="ArchiveRootDisplay"
                        Margin="0,4,0,8"
                        TextWrapping="Wrap"
                        IsTextSelectionEnabled="True" />
                    <Button
                        Content="Set archive root…"
                        HorizontalAlignment="Left"
                        Click="SetArchiveRoot_Click" />
                    <TextBlock Margin="0,24,0,8" Text="Caches" />
                    <Button
                        Content="Clear caches (metrics)"
                        HorizontalAlignment="Left"
                        Click="ClearCaches_Click" />
                    <Button
                        Margin="0,8,0,0"
                        Content="Clear caches + operation log"
                        HorizontalAlignment="Left"
                        Click="ClearCachesAndLog_Click" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </NavigationView>
</Window>
